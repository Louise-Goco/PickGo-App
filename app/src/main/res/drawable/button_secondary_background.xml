<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_secondary_pressed"/>
            <stroke android:width="1dp" android:color="@color/btn_secondary_border_pressed"/>
            <corners android:radius="50dp"/>
        </shape>
    </item>

    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_secondary_bg"/>
            <stroke android:width="2dp" android:color="@color/accent_color"/>
            <corners android:radius="50dp"/>
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_secondary_bg"/>
            <stroke android:width="1dp" android:color="@color/btn_secondary_border"/>
            <corners android:radius="50dp"/>
        </shape>
    </item>
</selector>